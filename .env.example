# Secure Agents Environment Variables
# Copy this file to .env and fill in your values.
#
# NOTE: For better security, use the macOS Keychain instead of env vars:
#   secure-agents auth setup
#
# Env vars are supported as a fallback but are visible to other processes.

# Email (only needed if not using OAuth2 or Keychain)
EMAIL_PASSWORD=your-gmail-app-password

# Ollama (local - no credentials needed, runs on your machine)
OLLAMA_HOST=http://localhost:11434
